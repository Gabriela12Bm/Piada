package com.mycompany.aaaaaaaa;

import java.util.Date;

public class Professor {

    private String nome;
    private String email;
    private String SIAPE;
    private int telefone;
    private String titulacao;
    private String area;
    private String regime;
    private int ingresso;
    private String formacao;

    public void setNome(String _nome) {
        nome = _nome;
    }

    public String getNome() {
        return nome;
    }

    public void setEmail(String _email) {
        email = _email;
    }

    public String getEmail() {
        return email;
    }

    public void setSIAPE(String _SIAPE) {
        SIAPE = _SIAPE;
    }

    public String getSIAPE() {
        return SIAPE;
    }

    public void setTelefone(int _telefone) {
        telefone = _telefone;
    }

    public int getTelefone() {
        return telefone;
    }

    public void setTitulacao(String _titulacao) {
        titulacao = _titulacao;
    }

    public String getTitulacao() {
        return titulacao;
    }

    public void setArea(String _area) {
        area = _area;
    }

    public String getArea() {
        return area;
    }

    public void setRegime(String _regime) {
        regime = _regime;
    }

    public String getRegime() {
        return regime;
    }

    public void setIngresso(int _ingresso) {
        ingresso = _ingresso;
    }

    public int getIngresso() {
        return ingresso;
    }

    public void setFormacao(String _formacao) {
        formacao = _formacao;
    }

    public String getFormacao() {
        return formacao;
    }
}
